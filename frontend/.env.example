# SplitFlow environment variables
# Copy this file to .env.local and fill in your values

# ── Stellar Network ────────────────────────────────────────────────────────
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# ── Contract IDs (populate after running: npx ts-node scripts/deploy.ts) ──
NEXT_PUBLIC_MANAGER_CONTRACT_ID=
NEXT_PUBLIC_DISTRIBUTOR_CONTRACT_ID=

# ── Token Contract ─────────────────────────────────────────────────────────
# Native XLM Stellar Asset Contract (Testnet)
NEXT_PUBLIC_XLM_SAC_ID=CAS3J7GYLGXMF6TDJBBYYSE3HQ6BBSMLNUQ34T6TZMYMW2EVH34XOWMA

# ── Observability (optional) ───────────────────────────────────────────────
